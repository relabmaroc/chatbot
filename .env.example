# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL=gpt-4o-mini

# Meta Compatibility Mode
# Set to 'true' for production webhooks (returns HTTP 200 on errors to prevent Meta retries)
# Set to 'false' for local development (returns proper HTTP status codes 4xx/5xx for debugging)
META_COMPAT_MODE=false

# Database Configuration
DATABASE_URL=sqlite:///./chatbot.db
# For production use PostgreSQL:
# DATABASE_URL=postgresql://user:password@host:port/database

# Application Configuration
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# Business Rules
HIGH_VALUE_THRESHOLD=5000
MAX_BOT_MESSAGES=10

# Rate Limiting
MAX_REQUESTS_PER_MINUTE=60

# n8n Workflow Configuration
USE_N8N_WORKFLOW=false
N8N_WEBHOOK_URL=https://n8n.your-domain.com/webhook/your-uuid
